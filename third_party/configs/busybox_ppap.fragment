# PicoPiAndPortable — busybox full config fragment
# Applied on top of allnoconfig via build-busybox.sh
#
# This is the "full" busybox used for transient commands (ls, cat, grep, …).
# Init and shell have dedicated binaries (busybox.init, busybox.sh), so
# CONFIG_INIT, CONFIG_HUSH, and FEATURE_SH_STANDALONE are excluded here.
#
# Key design choices:
#   - NOMMU mode (no fork, vfork-only)
#   - PIE linking with musl libc (R_ARM_RELATIVE relocations for XIP)
#   - Coreutils + editors + filesystem utilities only
#   - No Linux-specific features (sendfile, utmp, syslog)

# -- Platform -----------------------------------------------------------------
# CONFIG_STATIC is NOT set — we use -pie to get .rel.dyn relocations.
# The exec.c loader needs these to fix up function-pointer arrays
# (e.g. applet_main[]) whose entries are raw link-time addresses.
CONFIG_NOMMU=y
CONFIG_CROSS_COMPILER_PREFIX="arm-none-eabi-"

# -- Size optimization --------------------------------------------------------
CONFIG_LFS=y

# -- File operations ----------------------------------------------------------
CONFIG_LS=y
CONFIG_CAT=y
CONFIG_CP=y
CONFIG_MV=y
CONFIG_RM=y
CONFIG_MKDIR=y
CONFIG_RMDIR=y
CONFIG_LN=y
CONFIG_CHMOD=y

# -- Text processing ----------------------------------------------------------
CONFIG_ECHO=y
CONFIG_PRINTF=y
CONFIG_GREP=y
CONFIG_HEAD=y
CONFIG_TAIL=y
CONFIG_WC=y
CONFIG_SORT=y
CONFIG_SED=y

# -- Process management -------------------------------------------------------
CONFIG_KILL=y
CONFIG_SLEEP=y
CONFIG_PS=y
CONFIG_TOP=y
CONFIG_FEATURE_TOP_CPU_USAGE_PERCENTAGE=y
CONFIG_FEATURE_TOP_CPU_GLOBAL_PERCENTS=y

# -- Filesystem utilities -----------------------------------------------------
CONFIG_MOUNT=y
CONFIG_UMOUNT=y
CONFIG_DF=y

# -- Editor -------------------------------------------------------------------
CONFIG_VI=y
CONFIG_FEATURE_VI_COLON=y
CONFIG_FEATURE_VI_SEARCH=y

# -- System -------------------------------------------------------------------
CONFIG_UNAME=y
